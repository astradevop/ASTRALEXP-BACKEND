            "url": {
              "raw": "{{base_url}}/chat/parse/",
              "host": ["{{base_url}}"],
              "path": ["chat", "parse", ""]
            },
            "description": "Incomplete input — triggers a follow-up question response."
          }
        },
        {
          "name": "Parse — Calculation (2 items 50 each)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Bought 2 coffees at 80 each via PhonePe\",\n  \"save\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/chat/parse/",
              "host": ["{{base_url}}"],
              "path": ["chat", "parse", ""]
            },
            "description": "Tests calculation ability — Gemini should compute total = 160."
          }
        },
        {
          "name": "Parse — Relative time (yesterday night)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],

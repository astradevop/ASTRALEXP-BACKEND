    {
      "name": "🤖 Chat (Gemini AI Parser)",
      "item": [
        {
          "name": "Parse — Complete Expense (with auto-save)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Parse successful', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "pm.test('is_complete is true', () => pm.expect(res.is_complete).to.be.true);",
                  "pm.test('No follow-up needed', () => pm.expect(res.follow_up).to.be.null);",
                  "if (res.expense && res.expense.id) {",
                  "    pm.collectionVariables.set('expense_id', res.expense.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Had biriyani for 180 via GPay yesterday 8pm\",\n  \"save\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/chat/parse/",
              "host": ["{{base_url}}"],
              "path": ["chat", "parse", ""]
            },
            "description": "Full natural language parsing. `save: true` auto-creates the expense if all fields are extracted."
          }
        },
